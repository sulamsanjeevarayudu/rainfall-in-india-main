    }
   ],
   "source": [
    "# Graph 5: Top 10 Subdivisions by Annual Rainfall\n",
    "# Identifies the wettest regions in the dataset.\n",
    "\n",
    "top_subdivs_df = top_subdivs.reset_index()\n",
    "plt.figure(figsize=(12, 6))\n",
    "sns.barplot(\n",
    "    data=top_subdivs_df,\n",
    "    x=\"ANNUAL\",\n",
    "    y=\"SUBDIVISION\",\n",
    "    hue=\"SUBDIVISION\",\n",
