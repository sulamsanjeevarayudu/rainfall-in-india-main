   ],
   "source": [
    "# Graph 6: Monthly Contribution to Annual Rainfall (Pie Chart)\n",
    "# Visualizes how much each month contributes to the total yearly rainfall.\n",
    "\n",
    "monthly_total = df[monthly_cols].sum()\n",
    "plt.figure(figsize=(10, 10))\n",
    "plt.pie(monthly_total, labels=monthly_cols, autopct='%1.1f%%', startangle=90,\n",
    "        colors=sns.color_palette(\"pastel\"))\n",
    "plt.title(\"Monthly Contribution to Annual Rainfall\")\n",
    "plt.axis('equal')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
