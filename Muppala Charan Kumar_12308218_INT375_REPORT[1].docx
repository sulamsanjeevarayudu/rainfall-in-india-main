   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "df = pd.read_csv(\"C:/Users/hp/Downloads/Rainfall in india.csv\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b07a652e-6740-46d0-8833-83fceb2282e4",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(df.info())\n",
    "print(df.head())\n",
    "print(\"Shape:\", df.shape)\n",
    "print(\"Missing Values:\\n\", df.isnull().sum())\n",
    "df.fillna(0, inplace=True)\n",
    "print(\"Duplicates:\", df.duplicated().sum())\n",
    "df = df.drop_duplicates()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "f0d874d8-22e1-4009-ae3f-09fced25c0cd",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Graph 1: Distribution of Annual Rainfall\n",
    "# Shows the frequency and spread of yearly rainfall values.\n",
    "\n",
    "sns.set(style=\"whitegrid\")\n",
    "sns.histplot(df[\"ANNUAL\"], kde=True, color=\"#7E57C2\")\n",
    "plt.title(\"Distribution of Annual Rainfall\")\n",
    "plt.xlabel(\"Annual Rainfall (mm)\")\n",
    "plt.ylabel(\"Frequency\")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "2edef2f8-bd8f-472f-9fae-cf10f21d98ee",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Graph 2: Average Annual Rainfall Over Years\n",
    "# Reveals long-term rainfall trends.\n",
    "\n",
    "yearly_avg = df.groupby(\"YEAR\")[\"ANNUAL\"].mean()\n",
    "plt.figure(figsize=(12, 6))\n",
    "sns.lineplot(x=yearly_avg.index, y=yearly_avg.values, marker='o', color=\"#FF7043\")\n",
    "plt.title(\"Average Annual Rainfall Over Years\")\n",
    "plt.xlabel(\"Year\")\n",
    "plt.ylabel(\"Average Rainfall (mm)\")\n",
    "plt.grid(True)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "id": "e5b05938-50c3-4d35-b090-ce5299c132aa",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1000x800 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Graph 3: Monthly Rainfall Correlation Heatmap\n",
    "# Highlights relationships between months—useful for seasonal patterns.\n",
    "\n",
    "monthly_cols = ['JAN', 'FEB', 'MAR', 'APR', 'MAY', 'JUN', \n",
    "                'JUL', 'AUG', 'SEP', 'OCT', 'NOV', 'DEC']\n",
    "plt.figure(figsize=(10, 8))\n",
    "sns.heatmap(df[monthly_cols].corr(), annot=True, cmap=\"rocket_r\", fmt=\".2f\")\n",
    "plt.title(\"Monthly Rainfall Correlation\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "1ef7a76d-efb3-4985-8480-8d6993d1c9f2",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1400x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# Graph 4: Monthly Rainfall Distribution (Boxplot)\n",
    "# Helps understand variability and outliers in each month's rainfall.\n",
    "\n",
    "monthly_data = df[monthly_cols].melt(var_name=\"Month\", value_name=\"Rainfall\")\n",
    "plt.figure(figsize=(14, 6))\n",
    "sns.boxplot(x=\"Month\", y=\"Rainfall\", hue=\"Month\", data=monthly_data, palette=\"cool\", dodge=False)\n",
    "plt.title(\"Rainfall Distribution by Month\")\n",
    "plt.grid(True)\n",
    "plt.legend([],[], frameon=False)  # Hides the legend\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "c6457a15-4f3c-45c0-ab6d-c8bd63685ab7",
   "metadata": {},
